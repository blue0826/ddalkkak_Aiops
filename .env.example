# ddalkkak_Aiops 환경변수 예시 — 이 파일은 커밋됨(플레이스홀더만).
# 실제 값은 .env 에 넣고 .env 는 절대 커밋 금지 (회사 보안 룰).
# 신규 셋업: cp .env.example .env 후 값 채우기.

# --- 앱 서명/토큰 ---
# JWT 서명 키. 반드시 무작위 32바이트+ 로 교체. 예: python -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET=__REPLACE_WITH_RANDOM_SECRET__

# --- 자격증명 봉투 암호화 마스터 키 (KEK) ---
# JWT_SECRET 과 반드시 분리. 운영은 KMS/HSM 주입 권장. 유출 시 전 고객 자격증명 폐기.
# 예: python -c "import secrets;print(secrets.token_urlsafe(48))"
MASTER_KEK=__REPLACE_WITH_RANDOM_KEK__

# --- 데이터베이스 ---
# 개발: 미지정 시 config.py가 프로젝트 루트 기준 절대경로(aiops_mvp.db)를 자동 계산해
# 사용한다(실행 CWD·clone 경로 무관하게 항상 같은 파일). 운영/RLS 전환 시에만 아래처럼
# 명시적으로 오버라이드:
# DATABASE_URL=postgresql+asyncpg://user:pw@host:5432/aiops

# --- 배포 프로파일 ---
DEPLOYMENT_PROFILE=central
LICENSE_FILE=license.key

# --- CORS 허용 오리진 (콤마 구분) ---
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- LLM (L4, 개발단계는 미사용/모의; 운영 시 주입) ---
# 키/URL 미설정 시 자동으로 규칙 기반(template) 폴백 — 실 API 유료 호출 없음 (Phase 0 헌법 준수).
# LLM_ENABLED=true
# LLM_PROVIDER=auto              # auto | anthropic | openai_compat | template
# ANTHROPIC_API_KEY=__REPLACE_WITH_ANTHROPIC_API_KEY__
# LLM_GATEWAY_BASE_URL=          # 사내/에어갭 OpenAI 호환 엔드포인트 (예: https://internal-llm.local/v1)
# LLM_API_KEY=__REPLACE_WITH_GATEWAY_API_KEY__
# LLM_MODEL=claude-sonnet-5
